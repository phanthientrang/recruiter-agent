GREENNODE_CLIENT_ID=
GREENNODE_CLIENT_SECRET=
GREENNODE_AGENT_IDENTITY=
# LLM provider config (any OpenAI-compatible provider)
# For GreenNode AIP: use /agentbase-llm to get API key and set LLM_BASE_URL=https://maas-llm-aiplatform-hcm.api.vngcloud.vn/v1
# For OpenAI: set LLM_BASE_URL=https://api.openai.com/v1
# For Ollama: set LLM_BASE_URL=http://localhost:11434/v1 (no key needed)
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=
# Skill 1: Job folder creation
# Root directory that contains all job folders (set to your OneDrive-synced path)
JOBS_BASE_DIR=
# Skill 2: CV processing
# Full path to the Excel database file on OneDrive (local sync path)
EXCEL_PATH=
# Your name as it should appear in the TA Incharge column (defaults to Windows login if blank)
TA_INCHARGE=
# Seconds between scans of job folders for new CV files (default: 60)
CV_POLL_INTERVAL=60
